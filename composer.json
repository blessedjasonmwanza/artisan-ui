{
    "name": "blessedjasonmwanza/artisan-ui",
    "description": "GUI package for managing and monitoring Laravel artisan commands and their output",
    "type": "library",
    "require": {
        "laravel/framework": ">=10.0",
        "symfony/process": ">=6.0",
        "illuminate/support": ">=10.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "pestphp/pest": "^2.0|^3.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Blessedjasonmwanza\\ArtisanUi\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Blessed Jason Mwanza",
            "email": "mwanzabj@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "extra": {
        "laravel": {
            "providers": [
                "Blessedjasonmwanza\\ArtisanUi\\ArtisanUiServiceProvider"
            ]
        }
    }
}
